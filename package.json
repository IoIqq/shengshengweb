{
  "name": "shengsheng-ideology-studio",
  "version": "2.0.1",
  "description": "声声网络思政工作室网站，支持素材库、审片、待办、登录后台和服务器照片同步。",
  "main": "server/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node ./server/server.js",
    "dev": "nodemon ./server/server.js",
    "prod": "cross-env NODE_ENV=production node ./server/server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "lint": "eslint js/**/*.js server/**/*.js --ignore-pattern '*.backup.js'",
    "lint:fix": "eslint js/**/*.js server/**/*.js --fix --ignore-pattern '*.backup.js'",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html}\"",
    "maintenance": "node server/scripts/maintenance.js",
    "check": "npm run lint && npm audit",
    "clean": "node -e \"require('fs').rmSync('node_modules', {recursive: true, force: true})\" && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.2",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.3"
  }
}
