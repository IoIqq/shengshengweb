# 服务器监听
HOST=0.0.0.0
# 端口默认 48080（不常用高段，不易被别的程序占用）；被占用时会自动回退
PORT=48080
NODE_ENV=production

# 站点信息
SITE_TITLE=声声网络思政工作室
SITE_SUBTITLE=最低成本可部署工作台
PUBLIC_URL=

# 存储位置（支持绝对路径，例如外部硬盘：D:/StudioData/database.sqlite）
DATABASE_PATH=server/data/studio.sqlite
UPLOAD_DIR=server/uploads
INBOX_DIR=server/uploads/inbox

# 外部存储示例（取消注释以使用外部硬盘）
# DATABASE_PATH=D:/StudioData/database.sqlite
# UPLOAD_DIR=D:/StudioData/uploads
# INBOX_DIR=D:/StudioData/uploads/inbox

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password-here

# 访客账号
GUEST_USERNAME=guest
GUEST_PASSWORD=your-guest-password-here

# 安全密钥（必填，生产环境启动时校验；缺失将拒绝启动）
# 生成：openssl rand -hex 48
CSRF_SECRET=replace-with-openssl-rand-hex-48

SESSION_TTL_HOURS=72

# 上传限制
MAX_UPLOAD_MB=200
MAX_UPLOAD_FILES=30

# 自动扫描服务器 inbox 目录的间隔，0 表示关闭
INBOX_AUTO_SCAN_SECONDS=60

# 反向代理
TRUST_PROXY=1

# 飞书多维表格同步（设备申请双向同步）
# 在 https://open.feishu.cn 建自建应用拿 APP_ID/APP_SECRET，开通多维表格权限并把应用加为表格协作者
# 表格列名即契约：申请人 / 设备(设备名) / 用途 / 借用时间 / 预计归还 / 备注 / 审批状态(回写) / 审批人(回写)
FEISHU_SYNC_ENABLED=0
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_SYNC_INTERVAL_SEC=300
